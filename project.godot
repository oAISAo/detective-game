; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Detective Investigation"
config/description="A commercial detective investigation game where players solve crimes through evidence gathering, interrogation, and deduction."
run/main_scene="res://scenes/core/game_root.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/managers/game_manager.gd"
CaseManager="*res://scripts/managers/case_manager.gd"
SaveManager="*res://scripts/managers/save_manager.gd"
NotificationManager="*res://scripts/managers/notification_manager.gd"
EvidenceManager="*res://scripts/managers/evidence_manager.gd"
DaySystem="*res://scripts/systems/day_system.gd"
ActionSystem="*res://scripts/systems/action_system.gd"
EventSystem="*res://scripts/systems/event_system.gd"
DialogueSystem="*res://scripts/systems/dialogue_system.gd"
ScreenManager="*res://scripts/ui/screen_manager.gd"
ToolManager="*res://scripts/systems/tool_manager.gd"
LocationInvestigationManager="*res://scripts/managers/location_investigation_manager.gd"
InterrogationManager="*res://scripts/managers/interrogation_manager.gd"
BoardManager="*res://scripts/managers/board_manager.gd"
TimelineManager="*res://scripts/managers/timeline_manager.gd"
TheoryManager="*res://scripts/managers/theory_manager.gd"
LabManager="*res://scripts/managers/lab_manager.gd"
SurveillanceManager="*res://scripts/managers/surveillance_manager.gd"
WarrantManager="*res://scripts/managers/warrant_manager.gd"
ConclusionManager="*res://scripts/managers/conclusion_manager.gd"
AssetFallback="*res://scripts/systems/asset_fallback.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[gui]

theme/custom="res://resources/themes/main_theme.tres"

[input]

toggle_debug_panel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194332,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
