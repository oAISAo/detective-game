## UIColors.gd
## Shared color constants for the detective game UI.
## Centralizes repeated colors used across multiple screens.
class_name UIColors


## Muted text color for disabled/empty/placeholder states.
const MUTED: Color = Color(0.5, 0.48, 0.45)

## Secondary text color for hints and supplementary info.
const SECONDARY: Color = Color(0.6, 0.55, 0.4)

## Section header color for section titles and labels.
const HEADER: Color = Color(0.7, 0.68, 0.65)
