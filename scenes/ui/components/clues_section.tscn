[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/components/clues_section.gd" id="1_script"]

[node name="CluesSection" type="VBoxContainer"]
size_flags_vertical = 3
theme_override_constants/separation = 10
script = ExtResource("1_script")

[node name="HeaderMargin" type="MarginContainer" parent="."]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/margin_bottom = 8

[node name="Header" type="Label" parent="HeaderMargin"]
layout_mode = 2
text = "EVIDENCE DISCOVERED"
theme_type_variation = &"SectionHeader"

[node name="ClueScroll" type="ScrollContainer" parent="."]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
horizontal_scroll_mode = 0
vertical_scroll_mode = 2

[node name="ClueListMargin" type="MarginContainer" parent="ClueScroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/margin_left = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_top = 4
theme_override_constants/margin_bottom = 4

[node name="ClueGrid" type="GridContainer" parent="ClueScroll/ClueListMargin"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
columns = 2
theme_override_constants/h_separation = 24
theme_override_constants/v_separation = 20
