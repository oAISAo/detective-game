	"interrogation_sessions": [
		{
			"person_id": "p_mark",
			"initial_dialogue": "I already told the police what happened.\nI stopped by to talk to Daniel, we argued a little, and then I left.\nThat's it.",
			"initial_statement_ids": ["stmt_mark_visit", "stmt_mark_argument", "stmt_mark_departure_time"],
			"base_topic_ids": ["topic_reason_for_visit", "topic_departure_time", "topic_relationship"],
			"pressure_gate": 1,
			"rejection_texts": [
				"He barely reacts to that.",
				"That doesn't seem to shake his story.",
				"He dismisses it immediately.",
				"That isn't enough to challenge this point."
			],
			"pressure_dialogue": "You're trying to pin this on me because I lied.\nThat doesn't make me a murderer.",
			"break_dialogue": "Fine.\nDaniel found out about the money.\nHe said he was going to expose everything the next morning.\nI panicked, alright?\nBut when I left, he was still alive.",
			"break_statement_ids": ["stmt_mark_deeper_admission"],
			"break_unlocks": ["topic_who_else_knew"]
		},
		{
			"person_id": "p_sarah",
			"initial_dialogue": "Sarah clutches her hands nervously. 'I live next door. I heard shouting that night, but I was too scared to look.'",
			"initial_statement_ids": ["stmt_sarah_initial"],
			"base_topic_ids": ["topic_sarah_hallway"],
			"pressure_gate": 1,
			"rejection_texts": [
				"Sarah shakes her head. 'I don't know anything about that.'",
				"She looks confused. 'I... I don't understand what you're showing me.'"
			]
		},
		{
			"person_id": "p_julia",
			"initial_dialogue": "Julia sits rigid, arms crossed. 'Daniel was my husband. We were separated, but I had nothing to do with this.'",
			"initial_statement_ids": ["stmt_julia_initial"],
			"base_topic_ids": ["topic_julia_presence"],
			"pressure_gate": 2,
			"rejection_texts": [
				"Julia's expression hardens. 'That proves nothing.'",
				"She waves dismissively. 'This has nothing to do with me.'",
				"'You're wasting both of our time with this.'"
			]
		},
		{
			"person_id": "p_lucas",
			"initial_dialogue": "Lucas leans back casually. 'I'm the building maintenance guy. I was in the basement working all evening.'",
			"initial_statement_ids": ["stmt_lucas_initial"],
			"base_topic_ids": ["topic_lucas_work"],
			"pressure_gate": 1,
			"rejection_texts": [
				"Lucas shrugs. 'Don't know what that has to do with me.'",
				"He looks bored. 'I was in the basement. That's my story.'"
			]
		}
